:root {
  --bg: #0f172a;
  --card: #1e293b;
  --accent: #38bdf8;
  --accent-soft: #0ea5e9;
  --text: #e5e7eb;
  --muted: #9ca3af;
  --danger: #f97373;
  --success: #4ade80;
  --radius: 12px;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background: radial-gradient(circle at top, #1e293b, #020617);
  color: var(--text);
}

header {
  padding: 1.2rem 1rem 0.5rem;
  text-align: center;
}

header h1 {
  margin: 0;
  font-size: 1.4rem;
}

header p {
  margin: 0.3rem 0 0;
  color: var(--muted);
  font-size: 0.9rem;
}

main {
  max-width: 480px;
  margin: 0 auto;
  padding: 0.5rem 1rem 1.5rem;
}

.week-selector {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  margin-bottom: 0.8rem;
}

.week-selector select {
  padding: 0.3rem 0.6rem;
  border-radius: 999px;
  border: 1px solid var(--accent-soft);
  background: #020617;
  color: var(--text);
}

.day-buttons {
  display: flex;
  justify-content: space-between;
  gap: 0.4rem;
  margin-bottom: 1rem;
}

.day-btn {
  flex: 1;
  padding: 0.5rem 0;
  border-radius: 999px;
  border: 1px solid #334155;
  background: #020617;
  color: var(--text);
  font-size: 0.9rem;
  cursor: pointer;
}

.day-btn.active {
  background: var(--accent);
  border-color: var(--accent-soft);
  color: #0b1120;
  font-weight: 600;
}

.card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 0.9rem;
  box-shadow: 0 12px 30px rgba(15, 23, 42, 0.7);
  margin-bottom: 1rem;
}

.card h2 {
  margin-top: 0;
  font-size: 1.1rem;
}

.card p {
  margin: 0.2rem 0 0.6rem;
  color: var(--muted);
  font-size: 0.9rem;
}

.card ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.card li {
  margin-bottom: 0.35rem;
  font-size: 0.9rem;
}

.card li span.time {
  color: var(--accent);
  font-weight: 600;
}

.progress h2 {
  margin: 0 0 0.4rem;
  font-size: 1rem;
}

#checklist {
  list-style: none;
  padding: 0;
  margin: 0;
}

.check-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.4rem;
  font-size: 0.9rem;
}

.check-item input[type="checkbox"] {
  width: 18px;
  height: 18px;
}

.check-item label.completed {
  text-decoration: line-through;
  color: var(--muted);
}

footer {
  text-align: center;
  font-size: 0.8rem;
  color: var(--muted);
  padding-bottom: 0.8rem;
}
